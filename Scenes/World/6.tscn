[node name="dialogue" parent="." unique_id=1680645263 instance=ExtResource("9_ijtph")]
position = Vector2(571, 320)
sprite_frames = SubResource("SpriteFrames_3b45i")
questio = "Widzę dno... Czy to oznacza, że nadchodzi koniec świata i wielki głód?"
dial1 = "Basen olimpijski, jeśli tylko ktoś naleje tam wody, której i tak nie wypijesz."
dial2 = "To echo-lokator. Jak w nią uderzysz łapą o 3 rano, usłyszą cię nawet sąsiedzi."
dial3 = "To nowoczesna rzeźba. Służy do patrzenia z wyrzutem na właściciela."
dial4 = "To instrument muzyczny. Najlepiej brzmi, gdy przesuwasz go po kafelkach w nocy."
