questio = "Hej, co to za dziwne, metalowe kły, które kłapią bez powodu?"
dial1 = "Fryzjer domowy. Jeden ruch i pozbędziemy się tego kołtuna na ogonie."
dial2 = "To urządzenie do otwierania saszetek z mokrą karmą. Twoje wybawienie."
dial3 = "To narzędzie zbrodni na firankach. Ale oficjalnie: nie widziałeś ich nigdy na oczy."
dial4 = "To metalowe ptaki. Nie ruszaj, bo uszczypną cię w nos."
